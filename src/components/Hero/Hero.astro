---
import './Hero.css';
---

<header class="hero">
	<h1 id="title">Astro &times; GSAP</h1>
	<p id="subtitle">Every plugin registered. Scroll, drag, move.</p>
	<div class="hero-actions">
		<a
			class="hero-deploy"
			href="https://webflow.com/dashboard/cloud/deploy?repo=https://github.com/webflow-examples/astro-gsap"
		>
			<img src="https://webflow.com/img/deploy-dark.svg" alt="Deploy to Webflow" />
		</a>
		<a class="hero-cheatsheet" href="https://gsap.com/cheatsheet/">
			GSAP Cheatsheet <span aria-hidden="true">👀</span>
		</a>
		<a class="hero-cheatsheet" href="https://docs.astro.build/">
			Astro Docs <span aria-hidden="true">🚀</span>
		</a>
	</div>
</header>

<script>
	import './Hero.js';
</script>
